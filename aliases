# Unix
alias tlf="tail -f"
alias ln='ln -v'
alias mkdir='mkdir -p'
alias ...='../..'
alias l='ls'
alias ll='ls -al'
alias lh='ls -Alh'
alias -g G='| grep'
alias -g M='| less'
alias -g L='| wc -l'
alias -g ONE="| awk '{ print \$1}'"
alias e="$VISUAL"
alias v="$EDITOR"
alias vim="nvim -u ~/Dev/Me/dotfiles/config/nvim/init.vim"
alias rmnode="find . -name 'node_modules' -type d -prune -exec rm -rf {} \;"

for alias in ~/.zsh/aliases/*; do
  source "$alias"
done
